# Claude Code — user-local settings (per-machine, never committed)
.claude/settings.local.json

# Claude Code — ephemeral logs
.claude/logs/*
!.claude/logs/.gitkeep

# Personal local instructions (per-clone, never committed)
CLAUDE.local.md

# Backup files from manual file replacement workflows
*.backup-*

# Node
node_modules/

# Env
.env
.env.local

# OS
.DS_Store

# Claude Code — local worktree checkouts (git plumbing, never committed)
.claude/worktrees/

# Claude Code — memory dir: ignore scratch, keep curated logs
.claude/memory/*
!.claude/memory/patterns.md
!.claude/memory/current-state.md
!.claude/memory/lessons.md
