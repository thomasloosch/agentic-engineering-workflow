# Normalize line endings to LF in the repo and on checkout, on every OS.
# Without this, the Windows/MINGW (Git Bash) runtime reintroduces CRLF and
# turns one-line edits into whole-repo noise diffs.
* text=auto eol=lf

# Shell scripts run on Linux (Hetzner) and WSL2 — CRLF breaks the shebang.
# Redundant with the rule above, but documents the hard requirement.
*.sh text eol=lf
